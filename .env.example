# Database Configuration
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# Application Configuration
APP_NAME=Final Report System
APP_VERSION=1.0.0
BASE_URL=http://localhost/finalReport

# Security Configuration
SESSION_TIMEOUT=3600
CSRF_TOKEN_NAME=csrf_token
TWO_FACTOR_REQUIRED=true

# Pagination Configuration
RECORDS_PER_PAGE=25
MAX_RECORDS_PER_PAGE=100

# User Roles
ROLE_SUPER_ADMIN=super_admin
ROLE_ADMIN=admin
ROLE_USER=user

# Dashboard Colors
DASHBOARD_BG=#1a1a1a
DASHBOARD_SURFACE=#2d2d2d
DASHBOARD_CARD=#363636
DASHBOARD_BORDER=#404040
DASHBOARD_TEAL=#14b8a6
DASHBOARD_TEAL_DIM=rgba(20, 184, 166, 0.1)
DASHBOARD_GOLD=#f59e0b
DASHBOARD_ROSE=#f43f5e
DASHBOARD_BLUE=#3b82f6
DASHBOARD_PURPLE=#8b5cf6
DASHBOARD_GREEN=#10b981
DASHBOARD_TEXT=#f8fafc
DASHBOARD_MUTED=#94a3b8
DASHBOARD_DIM=#64748b

# Debug Mode (set to true for development)
DEBUG_MODE=false