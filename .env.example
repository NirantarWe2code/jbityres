# Database Configuration
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# Application Configuration
APP_NAME=Final Report System
APP_VERSION=1.0.0
BASE_URL=http://localhost/finalReport
# After login / 2FA success (default: JBI Full Dashboard)
# POST_LOGIN_REDIRECT=http://localhost/finalReport/pages/jbi-dashboard/index.php

# Security Configuration
SESSION_TIMEOUT=3600
CSRF_TOKEN_NAME=csrf_token
# When true: new users get no session until setup_2fa.php (QR + verify); existing TOTP users get OTP on login.
TWO_FACTOR_REQUIRED=true

# Pagination Configuration
RECORDS_PER_PAGE=25
MAX_RECORDS_PER_PAGE=100

# User Roles
ROLE_SUPER_ADMIN=super_admin
ROLE_ADMIN=admin
ROLE_USER=user

# Dashboard Colors (deeper navy, clear accents — simple to read)
DASHBOARD_BG=#0b1120
DASHBOARD_SURFACE=#141c2c
DASHBOARD_CARD=#1a2744
DASHBOARD_BORDER=#2f3d52
DASHBOARD_TEAL=#14b8a6
DASHBOARD_TEAL_DIM=rgba(20, 184, 166, 0.14)
DASHBOARD_TEAL_DARK=#0d9488
DASHBOARD_TEAL_SOFT=rgba(20, 184, 166, 0.1)
DASHBOARD_GOLD=#f59e0b
DASHBOARD_ROSE=#f43f5e
DASHBOARD_BLUE=#7a8fa4
DASHBOARD_PURPLE=#697586
DASHBOARD_GREEN=#5c9990
DASHBOARD_TEXT=#f8fafc
DASHBOARD_MUTED=#94a3b8
DASHBOARD_DIM=#64748b

# Debug Mode (set to true for development)
DEBUG_MODE=false